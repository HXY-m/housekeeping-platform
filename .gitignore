# ==========================================
# 1. 编译与运行输出 (Heavy Hitters)
# ==========================================
target/
bin/
build/
out/
.gradle/
dist/
dist-ssr/
node_modules/
.temp/
.cache/

# ==========================================
# 2. IDE 与 编辑器 (The "Invisible" Clutter)
# ==========================================
# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr
cmake-build-*/
# 即使不忽略 .idea，也必须忽略下面这个，它每秒都在变
.idea/workspace.xml
.idea/usage.statistics.xml
.idea/tasks.xml
.idea/shelf/
.idea/dictionaries/

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
.history/

# 其他编辑器
*.swp
*.bak
*~
.classpath
.project
.settings/

# ==========================================
# 3. 日志、临时文件与进程 (The Noise)
# ==========================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
pid
*.pid
*.seed
*.pid.lock

# ==========================================
# 4. 数据库与系统产生的垃圾 (Safety & Cleanliness)
# ==========================================
# MySQL / Redis 产生的临时文件或导出
#*.sql
*.hprof
*.pyc
dump.rdb
uploads/

# 操作系统
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ==========================================
# 5. 环境与密钥 (Security - DO NOT REMOVE)
# ==========================================
.env
*.local
.env.*.local
*.pem
*.key
*.p12
*.jks